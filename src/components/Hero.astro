---
import Icon from './Icon.astro';
import { profile } from '../data/site';
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center px-6 py-24"
>
  <div class="text-center max-w-2xl mx-auto">
    <img
      src="/images/pfp.jpg"
      alt="David Cole"
      class="w-36 h-36 md:w-40 md:h-40 rounded-full object-cover mx-auto mb-6 ring-4 ring-[#00b4d8]/40"
    />

    <h1 class="text-4xl md:text-5xl font-bold text-[#e0e0e0] mb-1">
      {profile.name}
    </h1>

    <p class="text-[#a0a0a0] text-sm mb-4">{profile.pronouns}</p>

    <p class="text-lg md:text-xl text-gold font-medium mb-3">
      {profile.title}
    </p>

    <p class="text-[#a0a0a0] text-base md:text-lg mb-10 leading-relaxed">
      {profile.tagline}
    </p>

    <div class="flex justify-center gap-3 flex-wrap">
      {profile.socials.map((s) => (
        <a
          href={s.href}
          target={s.icon !== 'email' ? '_blank' : undefined}
          rel={s.icon !== 'email' ? 'noopener noreferrer' : undefined}
          aria-label={s.label}
          class="w-11 h-11 rounded-full flex items-center justify-center border border-white/10 text-[#a0a0a0] hover:text-[#00b4d8] hover:border-[#00b4d8] transition-colors duration-200"
        >
          <Icon name={s.icon} class="w-5 h-5" />
        </a>
      ))}
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 animate-bounce">
    <span class="text-[#404040] text-xs tracking-widest uppercase select-none">Scroll</span>
    <svg class="w-4 h-4 text-[#404040]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
