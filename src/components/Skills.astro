---
import SkillCard from './SkillCard.vue';
import { skills } from '../data/site';
---

<section id="skills" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-[#e0e0e0] mb-2 text-center">Skills</h2>
    <div class="w-12 h-0.5 bg-gold mx-auto mb-10"></div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 gap-4">
      {skills.map((skill) => (
        <SkillCard skill={skill} client:only="vue" />
      ))}
    </div>
  </div>
</section>
