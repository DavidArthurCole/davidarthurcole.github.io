---
import { about } from '../data/site';
---

<section id="about" class="py-24 px-6">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-[#e0e0e0] mb-2 text-center">About</h2>
    <div class="w-12 h-0.5 bg-gold mx-auto mb-10"></div>

    <div
      class="rounded-xl border border-white/8 p-8 text-[#a0a0a0] text-base leading-relaxed"
      style="background: rgba(255,255,255,0.04); backdrop-filter: blur(4px);"
    >
      {about}
    </div>
  </div>
</section>
