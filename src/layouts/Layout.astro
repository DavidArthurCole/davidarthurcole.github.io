---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'David Cole | ServiceNow Architect',
  description = 'Applications Developer III and ServiceNow Architect at Rochester Institute of Technology, building enterprise-grade solutions for 20,000+ users.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {Astro.site && <link rel="canonical" href={Astro.site.href.replace(/\/$/, '')} />}
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <div class="app-container">
      <slot />
    </div>
    <div id="hover-overlay"></div>
  </body>
</html>
